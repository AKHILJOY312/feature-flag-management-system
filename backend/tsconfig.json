{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node16" /* Tells TS how to look up modules without needing baseUrl */,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Updated Paths (no longer depending on baseUrl) */
    "paths": {
      "@/*": ["./src/*"]
    },

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "eslint.config.mts"],
  "ts-node": {
    "files": true
  }
}
